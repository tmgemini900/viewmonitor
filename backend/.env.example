# ViewMonitor Pro — Ortam Değişkenleri
# Bu dosyayı kopyalayın: cp .env.example .env
# .env dosyasını asla git'e push ETMEYİN (.gitignore'a ekleyin)

# ── Veritabanı ──────────────────────────────────────────
# Docker için: /app/data/viewmonitor.db (docker-compose.yml volume ile uyumlu)
# Render için: /var/data/viewmonitor.db (Render Disk servisi gerekli)
# Yerel test:  ./data/viewmonitor.db
DB_PATH=/app/data/viewmonitor.db

# ── Log ─────────────────────────────────────────────────
LOG_PATH=/app/data/viewmonitor.log

# ── Güvenlik ─────────────────────────────────────────────
# API Key koruması — boş bırakılırsa auth devre dışı kalır
# Frontend'den X-Api-Key header'ı ile gönderilmeli
API_KEY=

# ── CORS ─────────────────────────────────────────────────
# GitHub Pages URL'inizi buraya yazın (kendi kullanıcı adınızla)
# Birden fazla origin virgülle ayrılabilir
ALLOW_ORIGIN=https://tmgemini900.github.io

# ── Twitter (Opsiyonel — Twitter API v2 Bearer Token) ───
# Nitter instance'ları çalışmıyorsa Twitter resmi API'si için
TWITTER_BEARER=

# ── Port ─────────────────────────────────────────────────
# Render.com bu değeri otomatik sağlar, değiştirmeyin
# Yerel test için: 8080
PORT=8080
